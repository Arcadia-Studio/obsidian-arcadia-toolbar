  title.textContent = "Text alignment";
  dropdown.appendChild(title);
  const alignments = [
    { icon: "align-left", label: "Align left", value: "left" },
    { icon: "align-center", label: "Align center", value: "center" },
    { icon: "align-right", label: "Align right", value: "right" },
