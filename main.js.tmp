    e.preventDefault();
    e.stopPropagation();
    if (ctx)
      removeHeading(ctx.editor);
    closeDropdowns(plugin);
  });
  dropdown.appendChild(removeItem);
  positionDropdown(plugin, dropdown, anchor);
}
function openAlignmentDropdown(plugin, anchor, ctx) {
