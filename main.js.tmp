      if (activeCtx) {
        insertSlideThemeFrontmatter(activeCtx.editor, theme.value);
      }
      closeDropdowns(plugin);
    });
    dropdown.appendChild(item);
  }
  positionDropdown(plugin, dropdown, anchor);
}

